DATABASE_URL=postgresql+asyncpg://llmref:llmref@localhost:5432/llmref
TEST_DATABASE_URL=postgresql+asyncpg://llmref:llmref@localhost:5432/llmref_test

# JWT signing secret — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Bootstrap admin account (created on first startup if no admin exists)
# Default: admin/admin — change the password after first login
BOOTSTRAP_ADMIN_LOGIN_ID=admin
BOOTSTRAP_ADMIN_PASSWORD=admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin
